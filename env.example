# Application Configuration
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=DEBUG

# Debug
DEBUG=true

# Database
DB_AUTO_MIGRATE=true

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["*"]

# Database - Primary (Master) - Port 5433 (+1 from 5432)
DB_MASTER_HOST=localhost
DB_MASTER_PORT=5433
DB_MASTER_USERNAME=user
DB_MASTER_PASSWORD=1234
DB_MASTER_DATABASE=app_db

# Database - Secondary (Replica) - Port 5434 (+1 from 5433)
DB_REPLICA_HOST=localhost
DB_REPLICA_PORT=5434
DB_REPLICA_USERNAME=user
DB_REPLICA_PASSWORD=1234
DB_REPLICA_DATABASE=app_db

# Redis - Port 7004 (+1 from 7003)
REDIS_HOST=localhost
REDIS_PORT=7004
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CLUSTER_MODE=false  # Set to false for single node in light mode

# RabbitMQ - Port 5673 (+1 from 5672), Management 15673 (+1 from 15672)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5673
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_VIRTUAL_HOST=/

# Kafka - Port 9093 (+1 from 9092)
KAFKA_BOOTSTRAP_SERVERS=["localhost:9093"]
KAFKA_CLIENT_ID=fastapi-app
KAFKA_GROUP_ID=fastapi-group

# Prometheus - Port 9091 (+1 from 9090)
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9091

# Enable Metrics
ENABLE_METRICS=true
